# Copy to .env and adjust for your Mac.
# cp .env.example .env

# Approved library (genre folders) — single root
# SETA_TRACKS_ROOT=~/Music/tracks

# Multiple curated roots (os.pathsep-separated)
# SETA_TRACKS_ROOTS=~/Music/tracks:~/Other/Approved

# Downloads / intake folder — single root
# SETA_CURATE_ROOT=~/Downloads/To Curate

# Multiple uncurated roots (os.pathsep-separated)
# SETA_CURATE_ROOTS=~/Downloads/To Curate:~/Incoming

# Web UI port
# SETA_PORT=8765
